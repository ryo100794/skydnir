{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Codex: start",
      "type": "shell",
      "command": "codex",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    },
    {
      "label": "Codex: version",
      "type": "shell",
      "command": "codex --version",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Skydnir: show paths",
      "type": "shell",
      "command": "skydnir-paths",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Skydnir: list projects",
      "type": "shell",
      "command": "skydnir-projects",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Skydnir: create project from template",
      "type": "shell",
      "command": "skydnir-new-project ${input:skydnirProjectName} ${input:skydnirTemplateName}",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Skydnir: docker version",
      "type": "shell",
      "command": "skydnir-docker version",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Skydnir: build current project",
      "type": "shell",
      "command": "skydnir-docker build -t local/skydnir-current:latest /pdocker/project",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Skydnir: compose up current project",
      "type": "shell",
      "command": "skydnir-compose -f /pdocker/project/compose.yaml up --detach --build && skydnir-compose -f /pdocker/project/compose.yaml ps",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Skydnir: compose logs current project",
      "type": "shell",
      "command": "skydnir-compose -f /pdocker/project/compose.yaml logs --tail=120",
      "options": {
        "cwd": "/workspace"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "skydnirProjectName",
      "type": "promptString",
      "description": "New project directory name",
      "default": "my-project"
    },
    {
      "id": "skydnirTemplateName",
      "type": "promptString",
      "description": "Template name, installed project name, or blank",
      "default": "blank"
    }
  ]
}
