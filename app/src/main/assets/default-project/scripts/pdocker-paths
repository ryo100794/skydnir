#!/usr/bin/env bash
set -euo pipefail

show_path() {
  local label="$1"
  local path="$2"
  local state="missing"
  if [[ -S "$path" ]]; then
    state="socket"
  elif [[ -d "$path" ]]; then
    state="directory"
  elif [[ -e "$path" ]]; then
    state="present"
  fi
  printf '%-24s %s (%s)\n' "$label:" "$path" "$state"
}

workspace="${SKYDNIR_WORKSPACE_DIR:-${PDOCKER_WORKSPACE_DIR:-/workspace}}"
project="${SKYDNIR_PROJECT_DIR:-${PDOCKER_PROJECT_DIR:-/pdocker/project}}"
projects="${SKYDNIR_PROJECTS_DIR:-${PDOCKER_PROJECTS_DIR:-/pdocker/projects}}"
home="${SKYDNIR_HOME:-${PDOCKER_HOME:-/pdocker/host}}"
engine="${SKYDNIR_ENGINE_SOCKET:-${PDOCKER_ENGINE_SOCKET:-$home/pdockerd.sock}}"
documents="${SKYDNIR_DOCUMENTS_MOUNT:-${PDOCKER_DOCUMENTS_MOUNT:-/documents}}"
shared_documents="${SKYDNIR_SHARED_DOCUMENTS_MOUNT:-${PDOCKER_SHARED_DOCUMENTS_MOUNT:-/shared}}"

show_path "workspace" "$workspace"
show_path "current project" "$project"
show_path "project library" "$projects"
show_path "Skydnir home" "$home"
show_path "engine socket" "$engine"
show_path "documents" "$documents"
show_path "shared documents" "$shared_documents"
show_path "docker socket" "/var/run/docker.sock"

echo
echo "Android app paths:"
echo "  filesDir/pdocker"
echo "  Documents/pdocker/projects"
echo "  Documents/pdocker/volumes"
echo "  Documents/pdocker/shared"
echo "  filesDir/pdocker/pdockerd.sock"

echo
engine_env_helper="$(command -v skydnir-engine-env || command -v pdocker-engine-env)"
if docker_host="$("$engine_env_helper" --value 2>/dev/null)"; then
  echo "Engine available: DOCKER_HOST=$docker_host"
else
  echo "Engine unavailable: start skydnird in the app and mount its socket/path into this container."
fi
