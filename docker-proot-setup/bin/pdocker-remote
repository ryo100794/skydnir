#!/usr/bin/env bash
# Skydnir remote Docker CLI compatibility wrapper.
# Use this when you need full Docker features (build, port mapping, etc.)
#
# Setup:
#   export DOCKER_HOST=tcp://your-server:2375
#   # or via SSH:
#   export DOCKER_HOST=ssh://user@your-server
#
# Usage:
#   skydnir-remote build -t myapp .
#   skydnir-remote run -d -p 8080:80 nginx
#   skydnir-remote ps

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
DOCKER_BIN="$PROJECT_DIR/docker"
INVOKED_AS="$(basename "${BASH_SOURCE[0]}")"

if [[ "$INVOKED_AS" == "pdocker-remote" && "${PDOCKER_SUPPRESS_DEPRECATION_WARNING:-0}" != "1" ]]; then
    echo "Warning: pdocker-remote is deprecated. Use skydnir-remote instead." >&2
fi

if [[ ! -x "$DOCKER_BIN" ]]; then
    echo "Error: Docker CLI not found at $DOCKER_BIN" >&2
    exit 1
fi

if [[ -z "${DOCKER_HOST:-}" ]]; then
    echo "Error: DOCKER_HOST is not set." >&2
    echo "" >&2
    echo "Set it to connect to a remote Docker daemon:" >&2
    echo "  export DOCKER_HOST=tcp://your-server:2375" >&2
    echo "  export DOCKER_HOST=ssh://user@your-server" >&2
    exit 1
fi

exec "$DOCKER_BIN" "$@"
