VOLUMES_DIR = os.path.join(PDOCKER_HOME, "volumes")
NETWORKS_DIR = os.path.join(PDOCKER_HOME, "networks")
# Staging for crane blob downloads, layer tars, image save/load etc. On
# Android the process can't write to /tmp (system read-only); respect
# $PDOCKER_TMP_DIR (or $TMPDIR) so the bridge can point us at the app's
# filesDir. Fall back to /tmp on a regular Linux host.
PDOCKER_TMP = (os.environ.get("PDOCKER_TMP_DIR")
               or os.environ.get("TMPDIR")
               or "/tmp")
os.makedirs(PDOCKER_TMP, exist_ok=True)

_PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
CRANE = os.path.join(_PROJECT_DIR, "docker-bin", "crane")
LIBCOW = os.path.join(_PROJECT_DIR, "lib", "libcow.so")
LIBCOW_MUSL = os.path.join(_PROJECT_DIR, "lib", "libcow-musl.so")
PLATFORM = os.environ.get("PDOCKER_PLATFORM", "linux/arm64")
FALLBACK_RESOLV_CONF = (
    os.environ.get("PDOCKER_FALLBACK_RESOLV_CONF")
    or "nameserver 8.8.8.8\nnameserver 1.1.1.1\n"
)


def _host_resolv_conf_text():
    runtime_resolv = os.path.join(_PROJECT_DIR, "etc", "resolv.conf")
    try:
        with open(runtime_resolv) as f:
            data = f.read()
            if data.strip():
                return data
    except OSError:
        pass
    try:
        with open("/etc/resolv.conf") as f:
            data = f.read()
            if data.strip():
                return data
    except OSError:
        pass
    return FALLBACK_RESOLV_CONF


def _prepare_rootfs_runtime_files(rootfs):
    etc = os.path.join(rootfs, "etc")
    os.makedirs(etc, exist_ok=True)
    with open(os.path.join(etc, "resolv.conf"), "w") as f:
        f.write(_host_resolv_conf_text())
    if RUNTIME_BACKEND.kind == "direct" and os.environ.get("PDOCKER_APT_SANDBOX_ROOT", "1") != "0":
        apt_conf = os.path.join(etc, "apt", "apt.conf.d")
        os.makedirs(apt_conf, exist_ok=True)
        with open(os.path.join(apt_conf, "00pdocker-direct-sandbox"), "w") as f:
            f.write('APT::Sandbox::User "root";\n')
    if os.environ.get("PDOCKER_BUILD_TOOLS", "0") == "1":
        build_bin = os.path.join(rootfs, "usr", "local", "pdocker-build-bin")
        os.makedirs(build_bin, exist_ok=True)
        glslc = os.path.join(build_bin, "glslc")
        with open(glslc, "w") as f:
            f.write("""#!/bin/sh
profile="${PDOCKER_BUILD_VULKAN_SHADER_PROFILE:-bridge-safe}"
if [ "$profile" = "bridge-safe" ]; then
  for arg in "$@"; do
    case "$arg" in
      *feature-tests/coopmat.comp)
        echo "error: extension not supported: GL_KHR_cooperative_matrix" >&2
        exit 1
        ;;
      *feature-tests/coopmat2.comp)
        echo "error: extension not supported: GL_NV_cooperative_matrix2" >&2
        exit 1
        ;;
    esac
  done
fi
exec /usr/bin/glslc "$@"
""")
        os.chmod(glslc, 0o755)

# Optional prefix injected before every crane invocation. This is an explicit
# developer-supplied diagnostic hook only; the Android app uses the bridge-side
# CONNECT proxy instead of bundling or auto-discovering an external runtime.
# Value is pipe-separated argv.
_CRANE_WRAP_SPEC = os.environ.get("PDOCKER_CRANE_WRAP", "")
CRANE_WRAP = _CRANE_WRAP_SPEC.split("|") if _CRANE_WRAP_SPEC else []

def _crane(args):
    """Build the argv for a crane invocation, prepending CRANE_WRAP so every
    subprocess.run([CRANE, ...]) site uses explicit diagnostics uniformly."""
    crane_path = os.path.realpath(CRANE) if CRANE_WRAP else CRANE
    return CRANE_WRAP + [crane_path] + list(args)


def _run_crane(args, **kw):
    """Wrapper that runs a crane command and, on CalledProcessError, logs
    the captured stderr so container-land failures (DNS, TLS, proot)
    aren't swallowed. Drop-in replacement for subprocess.run at crane
    call sites."""
    argv = _crane(args)
    try:
        return subprocess.run(argv, **kw)
    except subprocess.CalledProcessError as e:
        tail = (e.stderr or b"").decode("utf-8", "replace").strip().splitlines()[-40:]
        log(f"crane failed (rc={e.returncode}): argv={argv}")
        for line in tail:
            log(f"crane stderr: {line}")
        raise

def _proot_runnable(path):
    """Check if this proot binary is executable on the current host.

    The bundled proot is built for Android (bionic, interpreter
    /system/bin/linker64) and will ENOENT at exec time on a regular
    Ubuntu/glibc host even though the file has +x. Probe with --help
    to catch that before we commit to it as the runner.
    """
    if not path or not os.path.isfile(path) or not os.access(path, os.X_OK):
        return False
    try:
        r = subprocess.run([path, "--version"],
                           stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL,
                           timeout=5)
        return r.returncode == 0
    except (OSError, subprocess.SubprocessError):
        return False


def _find_runner():
    # Explicit override only. pdocker no longer auto-discovers Termux/system
    # proot, because the Android app runtime must not silently depend on an
    # external ptrace backend.
    override = os.environ.get("PDOCKER_RUNNER")
    if override and _proot_runnable(override):
        return override
    return None

RUNNER = _find_runner()
REQUESTED_RUNTIME_BACKEND = os.environ.get("PDOCKER_RUNTIME_BACKEND", "auto").strip().lower()
DIRECT_EXECUTOR = os.environ.get("PDOCKER_DIRECT_EXECUTOR", "").strip()
if os.environ.get("PDOCKER_DIRECT_EXPERIMENTAL_PROCESS_EXEC"):
    os.environ.setdefault("PDOCKER_DIRECT_TRACE_SYSCALLS", "0")
    os.environ.setdefault("PDOCKER_DIRECT_TRACE_MODE", "seccomp")


def _env_flag(name):
    return os.environ.get(name, "").lower() in ("1", "true", "yes", "on")


def _runner_supports_cow_bind():
    if DIRECT_EXECUTOR and os.path.exists(DIRECT_EXECUTOR):
        try:
            proc = subprocess.run(
                [DIRECT_EXECUTOR, "--pdocker-direct-probe"],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=3,
            )
            output = proc.stdout.decode("utf-8", "replace")
            return proc.returncode == 0 and "cow-bind=1" in output
        except (OSError, subprocess.SubprocessError):
            return False
    if not RUNNER:
        return False
    try:
        r = subprocess.run([RUNNER, "--help"],
                           stdout=subprocess.PIPE,
                           stderr=subprocess.STDOUT,
                           timeout=5)
    except (OSError, subprocess.SubprocessError):
        return False
    return b"--cow-bind" in r.stdout


USE_COW_BIND = _env_flag("PDOCKER_USE_COW_BIND")
COW_BIND_AVAILABLE = USE_COW_BIND and _runner_supports_cow_bind()
if USE_COW_BIND and not COW_BIND_AVAILABLE:
    sys.stderr.write("[pdockerd] PDOCKER_USE_COW_BIND=1 requested but runner lacks --cow-bind; using libcow rootfs materialization\n")
    sys.stderr.flush()


class RuntimeBackend:
    def __init__(self, kind, runner=None):
        self.kind = kind
        self.runner = runner

    @property
    def driver_name(self):
        if self.kind == "proot":
            return "external-cow"
        if self.kind == "direct":
            return "pdocker-direct"
        return "chroot-cow"

    @property
    def operating_system(self):
        if self.kind == "proot":
            return "PRoot Ubuntu"
        if self.kind == "direct":
            return "Android direct runtime"
        return "chroot rootfs"

    @property
    def info_id(self):
        return f"PDOCKER:{self.kind.upper()}"

    def unavailable_message(self):
        if self.kind == "proot" and not self.runner:
            return "pdocker runtime error: PRoot backend selected but no runnable proot binary was found."
        return ""

    def process_unavailable_message(self):
        fault = self.unavailable_message()
        if fault:
            return fault
        if self.kind == "direct" and not direct_executor_can_execute_processes():
            return direct_executor_unavailable_message()
        return ""

    @property
    def can_execute_processes(self):
        return not self.process_unavailable_message()

    def build_argv(self, rootfs, argv, inner_env, workdir="/", binds=None, cow_bind=None, mode="run"):
        fault = self.unavailable_message()
        if fault:
            raise RuntimeError(fault)

        if self.kind == "direct":
            fault = self.process_unavailable_message()
            if fault:
                raise RuntimeError(fault)
            return _direct_runtime_argv(
                rootfs, argv, inner_env, workdir, binds=binds,
                cow_bind=cow_bind, mode=mode,
            )

        if self.kind == "proot":
            bind_args = ["-b", "/proc", "-b", "/sys", "-b", "/dev"]
            for b in (binds or []):
                parts = b.split(":")
                if len(parts) < 2:
                    continue
                host, container = parts[0], parts[1]
                if not host or not container:
                    continue
                if not os.path.exists(host):
                    try:
                        os.makedirs(host, exist_ok=True)
                    except OSError:
                        continue
                bind_args.extend(["-b", f"{host}:{container}"])

            cow_args = []
            if cow_bind:
                cow_args = [
                    "--cow-bind",
                    f"{cow_bind['upper']}:{cow_bind['lower']}:{cow_bind.get('guest_path', '/')}",
                ]
            return [self.runner, "-0", "-r", rootfs,
                    *cow_args,
                    *bind_args,
                    "-w", workdir or "/",
                    "/usr/bin/env", "-i", *inner_env, *argv]

        return ["env", "-i", *inner_env, "chroot", rootfs, *argv]


def _select_runtime_backend():
    """Select the execution backend.

    `auto` preserves today's behavior. `direct`/`no-proot` is intentionally
    selectable before it is complete so the APK and UI can exercise packaging
    and diagnostics without silently falling back to PRoot.
    """
    if REQUESTED_RUNTIME_BACKEND in ("direct", "no-proot", "noproot"):
        return RuntimeBackend("direct")
    if REQUESTED_RUNTIME_BACKEND == "proot":
        return RuntimeBackend("proot", RUNNER)
    if REQUESTED_RUNTIME_BACKEND == "chroot":
        return RuntimeBackend("chroot")
    if DIRECT_EXECUTOR:
        return RuntimeBackend("direct")
    return RuntimeBackend("chroot")


RUNTIME_BACKEND = _select_runtime_backend()


def runtime_backend_kind():
    return RUNTIME_BACKEND.kind


def runtime_driver_name():
    return RUNTIME_BACKEND.driver_name


def runtime_operating_system():
    return RUNTIME_BACKEND.operating_system


def runtime_info_id():
    return RUNTIME_BACKEND.info_id


def runtime_backend_unavailable_message():
    return RUNTIME_BACKEND.unavailable_message()


def runtime_process_unavailable_message():
    return RUNTIME_BACKEND.process_unavailable_message()


def _read_meminfo():
    info = {}
    try:
        with open("/proc/meminfo") as f:
            for line in f:
                key, _, rest = line.partition(":")
                parts = rest.strip().split()
                if parts and parts[0].isdigit():
                    info[key] = int(parts[0]) * 1024
    except OSError:
        pass
    return info


def _path_info(path):
    data = {"Path": path or "", "Exists": False}
    if not path:
        return data
    try:
        st = os.stat(path)
    except OSError as e:
        data["Error"] = str(e)
        return data
    data.update({
        "Exists": True,
        "Size": st.st_size,
        "Mode": oct(st.st_mode & 0o7777),
        "MTime": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(st.st_mtime)),
        "RealPath": os.path.realpath(path),
    })
    return data


def _library_probe(names, extra_paths=None):
    extra_paths = extra_paths or []
    for path in extra_paths:
        if path and os.path.exists(path):
            return {"Available": True, "Path": path}
    found = ""
    try:
        import ctypes.util
        for name in names:
            found = ctypes.util.find_library(name) or ""
            if found:
                break
    except Exception:
        found = ""
    return {"Available": bool(found), "Path": found}


def _device_node_probe(paths):
    return [{"Path": path, "Exists": os.path.exists(path)} for path in paths]


def _truth_flag(name):
    return os.environ.get(name, "").lower() in ("1", "true", "yes", "on")


def _read_json_file(path):
    if not path:
        return {}
    try:
        with open(path) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (OSError, ValueError, TypeError):
        return {}


def _read_env_file(path):
    env = {}
    if not path:
        return env
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                value = value.strip()
                if len(value) >= 2 and value[0] == value[-1] == '"':
                    value = value[1:-1].replace('\\"', '"').replace("\\\\", "\\")
                env[key.strip()] = value
    except OSError:
        pass
    return env


def collect_documents_environment():
    common_env = _read_env_file(os.path.join(PDOCKER_HOME, "projects", ".pdocker-common.env"))
    get = lambda key: os.environ.get(key) or common_env.get(key, "")
    mirror = get("PDOCKER_DOCUMENTS_SAF_MIRROR_HOST")
    sidecar = get("PDOCKER_DOCUMENTS_SAF_SIDECAR_HOST")
    contract = _read_json_file(os.path.join(sidecar, "contract.json")) if sidecar else {}
    access = get("PDOCKER_DOCUMENTS_ACCESS") or get("PDOCKER_DOCUMENTS_MODE")
    mediator = get("PDOCKER_DOCUMENTS_MEDIATOR")
    return {
        "Access": access,
        "Mediator": mediator,
        "TreeUri": get("PDOCKER_DOCUMENTS_TREE_URI"),
        "SelectedHostPath": get("PDOCKER_DOCUMENTS_SELECTED_HOST"),
        "DirectHostPath": get("PDOCKER_DOCUMENTS_DIRECT_HOST"),
        "MediatedHostPath": get("PDOCKER_DOCUMENTS_MEDIATED_HOST"),
        "MirrorRoot": mirror,
        "SidecarRoot": sidecar,
        "Mirror": _path_info(mirror),
        "Sidecar": _path_info(sidecar),
        "Contract": contract,
        "PosixBindMount": access == "direct-path-writable",
        "ConflictPolicy": "phase1-no-conflict-detection",
        "SyncApi": {
            "Status": "/system/documents/status",
            "SyncToTree": "/system/documents/sync-to-tree",
            "SyncFromTree": "/system/documents/sync-from-tree",
            "AndroidMediatorRequired": True,
        },
    }


def record_documents_sync_request(direction):
    status = collect_documents_environment()
    sidecar = status.get("SidecarRoot") or ""
    request = {
        "Direction": direction,
        "Status": "accepted",
        "Message": "Android SAF sync is executed by the app mediator; daemon records the requested operation only.",
        "CreatedAtMs": int(time.time() * 1000),
        "Documents": status,
    }
    if sidecar:
        try:
            os.makedirs(sidecar, exist_ok=True)
            with open(os.path.join(sidecar, f"requested-{direction}.json"), "w") as f:
                json.dump(request, f, indent=2)
                f.write("\n")
        except OSError as e:
            request["SidecarWriteError"] = str(e)
    return request


def collect_media_environment():
    """Return the Phase-1 media bridge contract without claiming capture."""
    container_dir = os.environ.get("PDOCKER_MEDIA_CONTAINER_DIR", "/run/pdocker-media")
    queue_socket = os.environ.get(
        "PDOCKER_MEDIA_QUEUE_SOCKET",
        os.path.join(container_dir, "pdocker-media.sock"),
    )
    shared_dir = os.environ.get("PDOCKER_MEDIA_SHARED_DIR", container_dir)
    descriptor_path = os.environ.get(
        "PDOCKER_MEDIA_DESCRIPTOR_PATH",
        os.path.join(container_dir, "pdocker-media-capabilities.json"),
    )
    descriptor = _read_json_file(os.environ.get("PDOCKER_MEDIA_DESCRIPTOR_HOST_PATH", ""))
    executor = os.environ.get("PDOCKER_MEDIA_EXECUTOR", "")
    executor_available = (
        os.environ.get("PDOCKER_MEDIA_EXECUTOR_AVAILABLE", "0") == "1"
        and bool(executor)
        and os.path.exists(executor)
    )
    camera_ready = executor_available and _truth_flag("PDOCKER_MEDIA_CAMERA_READY")
    audio_ready = executor_available and _truth_flag("PDOCKER_MEDIA_AUDIO_READY")
    capture_ready = executor_available and _truth_flag("PDOCKER_MEDIA_CAPTURE_READY")
    enabled = camera_ready or audio_ready or capture_ready
    status = os.environ.get("PDOCKER_MEDIA_STATUS", "")
    if not status:
        status = "executor-present-capture-disabled" if executor_available else "phase1-control-plane-only"
    capabilities = [
        c for c in os.environ.get(
            "PDOCKER_MEDIA_CAPABILITIES",
            "video.camera2,camera.front,camera.rear,audio.capture,audio.playback,audio.usb.multichannel",
        ).split(",")
        if c
    ]
    return {
        "Kind": "android-media-bridge-phase1",
        "Phase": "phase-1",
        "Status": status,
        "Scaffold": True,
        "Enabled": enabled,
        "CaptureReady": capture_ready,
        "CameraReady": camera_ready,
        "AudioReady": audio_ready,
        "ExecutorAvailable": executor_available,
        "ExecutorRole": os.environ.get("PDOCKER_MEDIA_EXECUTOR_ROLE", ""),
        "CommandApi": os.environ.get("PDOCKER_MEDIA_COMMAND_API", "pdocker-media-command-v1"),
        "AbiVersion": os.environ.get("PDOCKER_MEDIA_ABI_VERSION", "0.1"),
        "Contract": os.environ.get("PDOCKER_MEDIA_CONTRACT", "linux-like-socket-env-v1"),
        "RawDevicePassthrough": os.environ.get("PDOCKER_MEDIA_DEVICE_PASSTHROUGH", "0") == "1",
        "Capabilities": capabilities,
        "ContainerDir": container_dir,
        "QueueSocket": queue_socket,
        "SharedDir": shared_dir,
        "DescriptorPath": descriptor_path,
        "Descriptor": descriptor,
        "Video": {
            "Api": os.environ.get("PDOCKER_MEDIA_VIDEO_API", "android-camera2"),
            "Targets": ["camera.front", "camera.rear", "camera.external"],
            "Ready": camera_ready,
        },
        "Audio": {
            "Apis": [
                os.environ.get("PDOCKER_MEDIA_AUDIO_API", "android-audiorecord-audiotrack"),
                os.environ.get("PDOCKER_MEDIA_AUDIO_DEVICE_API", "android-audiomanager"),
            ],
            "Targets": ["audio.capture", "audio.playback", "audio.usb.multichannel"],
            "Ready": audio_ready,
        },
        "Reason": "Phase-1 exposes socket/env negotiation and Android capability truth only; capture/playback commands are not implemented",
    }


def collect_host_environment(api_version):
    uname = os.uname()
    meminfo = _read_meminfo()
    env_keys = [
        "PDOCKER_RUNTIME_BACKEND",
        "PDOCKER_DIRECT_EXECUTOR",
        "PDOCKER_GPU_EXECUTOR",
        "PDOCKER_GPU_EXECUTOR_AVAILABLE",
        "PDOCKER_GPU_COMMAND_API",
        "PDOCKER_GPU_SHIM_HOST_PATH",
        "PDOCKER_VULKAN_ICD_HOST_PATH",
        "PDOCKER_VULKAN_ICD_KIND",
        "PDOCKER_VULKAN_ICD_READY",
        "PDOCKER_OPENCL_ICD_HOST_PATH",
        "PDOCKER_OPENCL_ICD_KIND",
        "PDOCKER_OPENCL_ICD_READY",
        "PDOCKER_MEDIA_EXECUTOR",
        "PDOCKER_MEDIA_EXECUTOR_AVAILABLE",
        "PDOCKER_MEDIA_COMMAND_API",
        "PDOCKER_MEDIA_ABI_VERSION",
        "PDOCKER_MEDIA_STATUS",
        "PDOCKER_MEDIA_CONTRACT",
        "PDOCKER_MEDIA_DEVICE_PASSTHROUGH",
        "PDOCKER_MEDIA_CONTAINER_DIR",
        "PDOCKER_MEDIA_QUEUE_SOCKET",
        "PDOCKER_MEDIA_SHARED_DIR",
        "PDOCKER_MEDIA_DESCRIPTOR_PATH",
        "PDOCKER_MEDIA_VIDEO_API",
        "PDOCKER_MEDIA_AUDIO_API",
        "PDOCKER_MEDIA_AUDIO_DEVICE_API",
        "PDOCKER_MEDIA_CAPTURE_READY",
        "PDOCKER_MEDIA_CAMERA_READY",
        "PDOCKER_MEDIA_AUDIO_READY",
        "PDOCKER_DOCUMENTS_ACCESS",
        "PDOCKER_DOCUMENTS_MEDIATOR",
        "PDOCKER_DOCUMENTS_SAF_MIRROR_HOST",
        "PDOCKER_DOCUMENTS_SAF_SIDECAR_HOST",
        "PDOCKER_PLATFORM",
        "ANDROID_ROOT",
        "ANDROID_DATA",
        "TMPDIR",
    ]
    selected_env = {key: os.environ.get(key, "") for key in env_keys if os.environ.get(key, "")}
    helper_paths = {
        "DirectExecutor": os.environ.get("PDOCKER_DIRECT_EXECUTOR", DIRECT_EXECUTOR),
        "GpuExecutor": os.environ.get("PDOCKER_GPU_EXECUTOR", ""),
        "GpuShim": os.environ.get("PDOCKER_GPU_SHIM_HOST_PATH", ""),
        "VulkanIcd": os.environ.get("PDOCKER_VULKAN_ICD_HOST_PATH", ""),
        "OpenClIcd": os.environ.get("PDOCKER_OPENCL_ICD_HOST_PATH", ""),
        "MediaExecutor": os.environ.get("PDOCKER_MEDIA_EXECUTOR", ""),
        "Crane": CRANE,
        "Libcow": LIBCOW,
    }
    return {
        "Host": {
            "Hostname": socket.gethostname(),
            "Sysname": uname.sysname,
            "Release": uname.release,
            "Version": uname.version,
            "Machine": uname.machine,
        },
        "Hardware": {
            "ProcessorCount": os.cpu_count() or 1,
            "MemTotal": meminfo.get("MemTotal", 0),
            "MemAvailable": meminfo.get("MemAvailable", 0),
        },
        "Software": {
            "Python": sys.version.split()[0],
            "Executable": sys.executable,
            "Pid": os.getpid(),
            "Cwd": os.getcwd(),
        },
        "Runtime": {
            "Backend": runtime_backend_kind(),
