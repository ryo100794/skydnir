                "IcdKind": os.environ.get("PDOCKER_OPENCL_ICD_KIND", ""),
                "IcdReady": os.environ.get("PDOCKER_OPENCL_ICD_READY", "0") == "1",
                "IcdPath": os.environ.get("PDOCKER_OPENCL_ICD_HOST_PATH", ""),
                "Loader": _library_probe(
                    ["OpenCL"],
