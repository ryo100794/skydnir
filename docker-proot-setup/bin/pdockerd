from http.server import BaseHTTPRequestHandler


class BadRequest(Exception):
    """Client input failed request validation and should return HTTP 400."""


# ---- Configuration ----

PDOCKER_HOME = os.environ.get("PDOCKER_HOME", os.path.expanduser("~/.pdocker"))
