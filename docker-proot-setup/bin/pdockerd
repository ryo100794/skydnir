            "ExecutorRole": os.environ.get("PDOCKER_GPU_EXECUTOR_ROLE", ""),
            "LlmEngineLocation": os.environ.get("PDOCKER_GPU_LLM_ENGINE_LOCATION", ""),
            "VulkanIcdKind": os.environ.get("PDOCKER_VULKAN_ICD_KIND", ""),
            "VulkanIcdReady": os.environ.get("PDOCKER_VULKAN_ICD_READY", "0") == "1",
